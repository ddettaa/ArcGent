{
  "name": "arcgent",
  "version": "0.1.0",
  "description": "Autonomous signal-to-payment agents on Arc + Circle Agent Stack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:agent": "cd apps/agent && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "build": "bun run build:web",
    "test": "bun test",
    "lint": "bun run lint:web && bun run lint:agent",
    "lint:web": "cd apps/web && bun run lint",
    "lint:agent": "cd apps/agent && bun run lint"
  },
  "keywords": ["arc", "circle", "agent", "usdc", "payment", "autonomous", "monorepo"],
  "license": "MIT"
}
