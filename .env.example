# Arc Network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# USDC Contract (Arc Testnet)
USDC_CONTRACT=0x3600000000000000000000000000000000000000

# Circle Agent Stack
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here
CIRCLE_WALLET_ID=your_wallet_id_here

# Circle App Kit
CIRCLE_KIT_KEY=your_kit_key_here

# Signal Sources (Optional - for use cases)
GITHUB_TOKEN=ghp_your_github_token
AVIATIONSTACK_API_KEY=your_aviation_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
STRAVA_CLIENT_ID=your_strava_id

# Telegram Notifications (for REVIEW/MANUAL tier approvals)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# API Auth (for sensitive endpoints)
ARC_ADMIN_KEY=ag_your_admin_key_here
# Comma-separated extra keys: key:name:role
# ARC_API_KEYS=ag_key1:bot1:operator,ag_key2:dashboard:viewer

# Agent Config
AGENT_PRIVATE_KEY=your_wallet_private_key
AGENT_RULES_PATH=./config/rules.json
